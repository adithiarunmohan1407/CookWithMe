# -----------------------------------------------------------------------
# CookWithMe - Environment Variables Template
# -----------------------------------------------------------------------
# 1. Copy this file to ".env"  (cp .env.example .env)
# 2. Fill in your real values below
# 3. NEVER commit your actual .env file to version control
# -----------------------------------------------------------------------

# --- AI Provider Settings ---
# The AI integration is modular (see services/chatbot.py), so you can
# swap providers by changing AI_PROVIDER and the matching API key.
AI_PROVIDER=openai
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini

# --- Flask Settings ---
FLASK_SECRET_KEY=change-this-to-a-long-random-string
FLASK_ENV=development
FLASK_DEBUG=True
FLASK_PORT=5000

# --- Database Settings ---
DATABASE_PATH=data/cookwithme.db
